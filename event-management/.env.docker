# .env.docker
APP_ENV=dev
APP_DEBUG=1
APP_DOMAIN=localhost

# Database
DB_NAME=symfony
DB_USER=symfony
DB_PASSWORD=password
DB_ROOT_PASSWORD=root_password

# JWT
JWT_SECRET_KEY=/var/www/config/jwt/private.pem
JWT_PUBLIC_KEY=/var/www/config/jwt/public.pem
JWT_PASSPHRASE=your_secure_passphrase_here
JWT_TOKEN_TTL=3600

# WebAuthn
WEBAUTHN_RP_NAME="EventBooking App"