<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}EventBooking{% endblock %}</title>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
        <link rel="stylesheet" href="{{ asset('css/app.css') }}">
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <!-- Navigation -->
        <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_home') }}">
                    <i class="bi bi-calendar-event-fill me-2"></i>
                    EventBooking
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" 
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.get('_route') == 'app_home' %}active{% endif %}" 
                               href="{{ path('app_home') }}">
                                <i class="bi bi-house-door me-1"></i>
                                Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.get('_route') == 'app_events_list' %}active{% endif %}" 
                               href="{{ path('app_events_list') }}">
                                <i class="bi bi-calendar3 me-1"></i>
                                Events
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="categoriesDropdown" role="button" 
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-grid me-1"></i>
                                Categories
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="categoriesDropdown">
                                <li><a class="dropdown-item" href="{{ path('app_events_list', {'filter': 'upcoming'}) }}">
                                    <i class="bi bi-sun me-2"></i>Upcoming Events
                                </a></li>
                                <li><a class="dropdown-item" href="{{ path('app_events_list', {'filter': 'past'}) }}">
                                    <i class="bi bi-moon me-2"></i>Past Events
                                </a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="{{ path('app_events_list') }}">
                                    <i class="bi bi-grid-3x3-gap-fill me-2"></i>All Events
                                </a></li>
                            </ul>
                        </li>
                    </ul>
                    
                    <ul class="navbar-nav ms-auto">
                        {% if app.user %}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" 
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="user-avatar">
                                        <i class="bi bi-person-circle"></i>
                                    </div>
                                    <span class="user-name">{{ app.user.fullName|slice(0, 15) }}</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="bi bi-person me-2"></i>My Profile
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="{{ path('app_my_reservations') }}">
                                            <i class="bi bi-ticket me-2"></i>My Reservations
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_login') }}">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>
                                    Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link register-link" href="{{ path('app_register') }}">
                                    <i class="bi bi-person-plus me-1"></i>
                                    Register
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="main-content">
            <div class="container">
                <!-- Flash Messages -->
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success alert-dismissible fade show flash-message" role="alert">
                        <div class="flash-icon">
                            <i class="bi bi-check-circle-fill"></i>
                        </div>
                        <div class="flash-content">
                            {{ message }}
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}

                {% for message in app.flashes('error') %}
                    <div class="alert alert-danger alert-dismissible fade show flash-message" role="alert">
                        <div class="flash-icon">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                        </div>
                        <div class="flash-content">
                            {{ message }}
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}

                {% for message in app.flashes('warning') %}
                    <div class="alert alert-warning alert-dismissible fade show flash-message" role="alert">
                        <div class="flash-icon">
                            <i class="bi bi-exclamation-circle-fill"></i>
                        </div>
                        <div class="flash-content">
                            {{ message }}
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}

                {% block body %}{% endblock %}
            </div>
        </main>

        <!-- Footer -->
        <footer class="footer">
            <div class="container">
                <div class="footer-grid">
                    <div class="footer-section">
                        <h5 class="footer-title">
                            <i class="bi bi-calendar-event-fill me-2"></i>
                            EventBooking
                        </h5>
                        <p class="footer-description">
                            Discover amazing events and make unforgettable memories. Your gateway to the best experiences in town.
                        </p>
                    </div>

                    <div class="footer-section">
                        <h5 class="footer-title">Quick Links</h5>
                        <ul class="footer-links">
                            <li><a href="{{ path('app_home') }}"><i class="bi bi-chevron-right me-2"></i>Home</a></li>
                            <li><a href="{{ path('app_events_list') }}"><i class="bi bi-chevron-right me-2"></i>Events</a></li>
                            <li><a href="#"><i class="bi bi-chevron-right me-2"></i>About Us</a></li>
                            <li><a href="#"><i class="bi bi-chevron-right me-2"></i>Contact</a></li>
                        </ul>
                    </div>

                    <div class="footer-section">
                        <h5 class="footer-title">Categories</h5>
                        <ul class="footer-links">
                            <li><a href="{{ path('app_events_list', {'filter': 'upcoming'}) }}"><i class="bi bi-chevron-right me-2"></i>Upcoming Events</a></li>
                            <li><a href="{{ path('app_events_list', {'filter': 'past'}) }}"><i class="bi bi-chevron-right me-2"></i>Past Events</a></li>
                            <li><a href="#"><i class="bi bi-chevron-right me-2"></i>Music</a></li>
                            <li><a href="#"><i class="bi bi-chevron-right me-2"></i>Sports</a></li>
                        </ul>
                    </div>

                    <div class="footer-section">
                        <h5 class="footer-title">Contact Info</h5>
                        <ul class="footer-contact">
                            <li>
                                <i class="bi bi-geo-alt"></i>
                                <span>123 Event Street, City, Country</span>
                            </li>
                            <li>
                                <i class="bi bi-envelope"></i>
                                <span>info@eventbooking.com</span>
                            </li>
                            <li>
                                <i class="bi bi-telephone"></i>
                                <span>+1 234 567 890</span>
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="footer-bottom">
                    <div class="footer-bottom-content">
                        <p class="copyright">
                            &copy; {{ "now"|date("Y") }} EventBooking. All rights reserved.
                        </p>
                    </div>
                </div>
            </div>
        </footer>

        <!-- Back to Top Button -->
        <button id="backToTop" class="back-to-top" aria-label="Back to top">
            <i class="bi bi-arrow-up"></i>
        </button>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        
        <script>
            // Back to top button functionality
            const backToTopButton = document.getElementById('backToTop');
            
            window.addEventListener('scroll', () => {
                if (window.scrollY > 300) {
                    backToTopButton.classList.add('show');
                } else {
                    backToTopButton.classList.remove('show');
                }
            });
            
            backToTopButton.addEventListener('click', () => {
                window.scrollTo({
                    top: 0,
                    behavior: 'smooth'
                });
            });

            // Auto-dismiss flash messages after 5 seconds
            document.addEventListener('DOMContentLoaded', function() {
                const flashMessages = document.querySelectorAll('.flash-message');
                flashMessages.forEach(message => {
                    setTimeout(() => {
                        const closeButton = message.querySelector('.btn-close');
                        if (closeButton) {
                            closeButton.click();
                        }
                    }, 5000);
                });
            });
        </script>
        
        {% block javascripts %}{% endblock %}
    </body>
</html>