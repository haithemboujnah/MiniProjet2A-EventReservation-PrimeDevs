<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Admin - EventBooking{% endblock %}</title>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
        <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
        <link rel="stylesheet" href="{{ asset('css/notification.css') }}">
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <div class="admin-wrapper">
            <!-- Sidebar -->
            <aside class="admin-sidebar">
                <div class="sidebar-header">
                    <a href="{{ path('admin_dashboard') }}" class="sidebar-brand">
                        <i class="bi bi-calendar-event-fill"></i>
                        <span>EventBooking</span>
                    </a>
                </div>
                
                <nav class="sidebar-nav">
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.get('_route') == 'admin_dashboard' %}active{% endif %}" 
                               href="{{ path('admin_dashboard') }}">
                                <i class="bi bi-speedometer2"></i>
                                <span>Dashboard</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.get('_route') starts with 'admin_events' %}active{% endif %}" 
                               href="{{ path('admin_events_index') }}">
                                <i class="bi bi-calendar-event"></i>
                                <span>Events</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.get('_route') == 'admin_profile' %}active{% endif %}" 
                                href="{{ path('admin_profile') }}">
                                <i class="bi bi-person-circle"></i>
                                <span>My Profile</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_home') }}" target="_blank">
                                <i class="bi bi-eye"></i>
                                <span>View Site</span>
                            </a>
                        </li>
                    </ul>
                </nav>
                
                <div class="sidebar-footer">
                    <div class="admin-info">
                        <i class="bi bi-shield-lock"></i>
                        <div class="admin-details">
                            <span class="admin-name">{{ app.user.fullName ?? app.user.username }}</span>
                            <span class="admin-role">Administrator</span>
                        </div>
                    </div>
                    <a href="{{ path('admin_logout') }}" class="logout-btn" onclick="event.preventDefault(); document.getElementById('logout-form').submit();">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Logout</span>
                    </a>
                    <form id="logout-form" action="{{ path('admin_logout') }}" method="POST" style="display: none;">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                    </form>
                </div>
            </aside>

            <!-- Main Content -->
            <main class="admin-main">
                <div class="admin-header">
                    <button class="sidebar-toggle" id="sidebarToggle">
                        <i class="bi bi-list"></i>
                    </button>
                    
                    <div class="header-search">
                        <i class="bi bi-search"></i>
                        <input type="text" placeholder="Search...">
                    </div>
                    
                    <div class="header-actions">
                        <!-- Notification Bell with Badge -->
                        <div class="notification-wrapper">
                            <div class="notification-badge" id="notificationBell" data-bs-toggle="modal" data-bs-target="#notificationModal">
                                <i class="bi bi-bell"></i>
                                <span class="badge" id="notificationCount">0</span>
                            </div>
                        </div>
                        
                        <div class="admin-profile" onclick="window.location.href='{{ path('admin_profile') }}'" style="cursor: pointer;">
                            <div class="profile-info">
                                <span class="profile-name">{{ app.user.fullName ?? app.user.username }}</span>
                                <span class="profile-role">Admin</span>
                            </div>
                            <div class="profile-avatar">
                                <i class="bi bi-person-circle"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="admin-content">
                    <!-- Flash Messages -->
                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}

                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}

                    {% for message in app.flashes('warning') %}
                        <div class="alert alert-warning alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}

                    {% block body %}{% endblock %}
                </div>
                <div class="modal fade" id="notificationModal" tabindex="-1" aria-labelledby="notificationModalLabel" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered modal-lg">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="notificationModalLabel">
                                    <i class="bi bi-bell-fill text-primary me-2"></i>
                                    Notifications
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <div class="notification-tabs">
                                    <ul class="nav nav-tabs" id="notificationTabs" role="tablist">
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link active" id="all-tab" data-bs-toggle="tab" data-bs-target="#all" type="button" role="tab">
                                                <i class="bi bi-list-ul"></i>
                                                All Notifications
                                                <span class="badge bg-primary ms-2" id="allCount">0</span>
                                            </button>
                                        </li>
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link" id="unread-tab" data-bs-toggle="tab" data-bs-target="#unread" type="button" role="tab">
                                                <i class="bi bi-envelope"></i>
                                                Unread
                                                <span class="badge bg-danger ms-2" id="unreadCount">0</span>
                                            </button>
                                        </li>
                                    </ul>
                                    
                                    <div class="tab-content mt-3" id="notificationTabsContent">
                                        <!-- All Notifications Tab -->
                                        <div class="tab-pane fade show active" id="all" role="tabpanel">
                                            <div class="notification-list" id="allNotificationsList">
                                                <div class="text-center text-muted py-4">
                                                    <div class="spinner-border text-primary" role="status">
                                                        <span class="visually-hidden">Loading...</span>
                                                    </div>
                                                    <p class="mt-2">Loading notifications...</p>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <!-- Unread Notifications Tab -->
                                        <div class="tab-pane fade" id="unread" role="tabpanel">
                                            <div class="notification-list" id="unreadNotificationsList">
                                                <div class="text-center text-muted py-4">
                                                    <div class="spinner-border text-primary" role="status">
                                                        <span class="visually-hidden">Loading...</span>
                                                    </div>
                                                    <p class="mt-2">Loading notifications...</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn-mark-all" id="markAllReadBtn">
                                    <i class="bi bi-check2-all"></i>
                                    Mark All as Read
                                </button>
                                <button type="button" class="btn-close-simple" data-bs-dismiss="modal">
                                    <i class="bi bi-x-lg"></i>
                                    Close
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Notification Item Template (hidden) -->
                <template id="notificationTemplate">
                    <div class="notification-item">
                        <div class="notification-icon">
                            <i class="bi bi-person"></i>
                        </div>
                        <div class="notification-content">
                            <div class="notification-title"></div>
                            <div class="notification-details"></div>
                            <div class="notification-time"></div>
                        </div>
                        <div class="notification-actions">
                            <button class="btn-mark-read" title="Mark as read">
                                <i class="bi bi-check-circle"></i>
                            </button>
                        </div>
                    </div>
                </template>
            </main>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        
        <script>
            // Sidebar toggle
            document.getElementById('sidebarToggle').addEventListener('click', function() {
                document.querySelector('.admin-wrapper').classList.toggle('sidebar-collapsed');
            });

            // Auto-dismiss alerts
            document.addEventListener('DOMContentLoaded', function() {
                const alerts = document.querySelectorAll('.alert');
                alerts.forEach(alert => {
                    setTimeout(() => {
                        const closeButton = alert.querySelector('.btn-close');
                        if (closeButton) {
                            closeButton.click();
                        }
                    }, 5000);
                });
            });

                // Prevent back button after logout
            (function() {
                // Disable browser back/forward cache
                window.addEventListener('pageshow', function(event) {
                    if (event.persisted) {
                        window.location.reload();
                    }
                });

                // Check authentication status periodically
                let lastActivity = Date.now();
                const sessionTimeout = 30 * 60 * 1000; // 30 minutes

                // Check session every minute
                setInterval(function() {
                    if (Date.now() - lastActivity > sessionTimeout) {
                        // Session expired, redirect to login
                        window.location.href = '{{ path('admin_login') }}';
                    }
                }, 60000);

                // Update last activity on user interaction
                document.addEventListener('mousemove', function() {
                    lastActivity = Date.now();
                });
                document.addEventListener('keypress', function() {
                    lastActivity = Date.now();
                });
                document.addEventListener('click', function() {
                    lastActivity = Date.now();
                });

                // Handle AJAX request failures (if session expired)
                const originalFetch = window.fetch;
                window.fetch = function() {
                    return originalFetch.apply(this, arguments).then(response => {
                        if (response.status === 401 || response.status === 403) {
                            window.location.href = '{{ path('admin_login') }}';
                        }
                        return response;
                    });
                };
            })();

            class NotificationManager {
                constructor() {
                    this.bell = document.getElementById('notificationBell');
                    this.countBadge = document.getElementById('notificationCount');
                    this.modal = document.getElementById('notificationModal');
                    this.allList = document.getElementById('allNotificationsList');
                    this.unreadList = document.getElementById('unreadNotificationsList');
                    this.allCountSpan = document.getElementById('allCount');
                    this.unreadCountSpan = document.getElementById('unreadCount');
                    this.markAllBtn = document.getElementById('markAllReadBtn');
                    
                    this.notifications = [];
                    this.unreadCount = 0;
                    
                    this.init();
                }
                
                init() {
                    // Load notifications
                    this.loadNotifications();
                    
                    // Refresh every 30 seconds
                    setInterval(() => this.loadNotifications(), 30000);
                    
                    // Mark all as read
                    if (this.markAllBtn) {
                        this.markAllBtn.addEventListener('click', () => this.markAllAsRead());
                    }
                    
                    // Reset unread count when modal is opened
                    if (this.modal) {
                        this.modal.addEventListener('show.bs.modal', () => {
                            this.resetUnreadCount();
                        });
                    }
                }
                
                loadNotifications() {
                    fetch('{{ path('admin_notifications') }}')
                        .then(response => response.json())
                        .then(data => {
                            this.notifications = data.notifications;
                            this.unreadCount = data.total;
                            this.updateUI();
                        })
                        .catch(error => console.error('Error loading notifications:', error));
                }
                
                updateUI() {
                    // Update badge count
                    if (this.countBadge) {
                        this.countBadge.textContent = this.unreadCount;
                        this.countBadge.style.display = this.unreadCount > 0 ? 'flex' : 'none';
                    }
                    
                    // Update counts in tabs
                    if (this.allCountSpan) {
                        this.allCountSpan.textContent = this.notifications.length;
                    }
                    if (this.unreadCountSpan) {
                        this.unreadCountSpan.textContent = this.unreadCount;
                    }
                    
                    // Render notifications
                    this.renderNotifications('all', this.allList);
                    this.renderNotifications('unread', this.unreadList);
                }
                
                renderNotifications(type, container) {
                    if (!container) return;
                    
                    const filtered = type === 'unread' 
                        ? this.notifications.slice(0, this.unreadCount) // Simulate unread
                        : this.notifications;
                    
                    if (filtered.length === 0) {
                        container.innerHTML = `
                            <div class="notification-empty">
                                <i class="bi bi-bell-slash"></i>
                                <p>No notifications</p>
                            </div>
                        `;
                        return;
                    }
                    
                    let html = '';
                    filtered.forEach((notif, index) => {
                        html += `
                            <div class="notification-item ${index < this.unreadCount ? 'unread' : ''}" data-id="${notif.id}">
                                <div class="notification-icon">
                                    <i class="bi bi-person"></i>
                                </div>
                                <div class="notification-content">
                                    <div class="notification-title">
                                        New Reservation from ${notif.name}
                                    </div>
                                    <div class="notification-details">
                                        <span><i class="bi bi-envelope"></i> ${notif.email}</span>
                                        <span><i class="bi bi-calendar-event"></i> ${notif.event}</span>
                                    </div>
                                    <div class="notification-time">
                                        <i class="bi bi-clock"></i> ${notif.time_ago}
                                    </div>
                                </div>
                                <div class="notification-actions">
                                    <button class="btn-mark-read" onclick="notificationManager.markAsRead(${notif.id})" title="Mark as read">
                                        <i class="bi bi-check-circle"></i>
                                    </button>
                                </div>
                            </div>
                        `;
                    });
                    
                    container.innerHTML = html;
                }
                
                markAsRead(id) {
                    // Find and remove from unread
                    const index = this.notifications.findIndex(n => n.id === id);
                    if (index !== -1 && index < this.unreadCount) {
                        this.unreadCount--;
                        
                        // Send to server (optional)
                        fetch('{{ path('admin_notifications_mark_read') }}', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify({ ids: [id] })
                        });
                        
                        this.updateUI();
                    }
                }
                
                markAllAsRead() {
                    if (this.unreadCount === 0) return;
                    
                    // Mark all as read
                    this.unreadCount = 0;
                    
                    // Send to server
                    fetch('{{ path('admin_notifications_mark_read') }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({ 
                            ids: this.notifications.slice(0, this.unreadCount).map(n => n.id) 
                        })
                    });
                    
                    this.updateUI();
                }
                
                resetUnreadCount() {
                    // Optional: You might want to mark all as read when modal is opened
                    // this.markAllAsRead();
                }
            }

            // Initialize notification manager
            document.addEventListener('DOMContentLoaded', function() {
                window.notificationManager = new NotificationManager();
            });
        </script>
        
        {% block javascripts %}{% endblock %}
    </body>
</html>