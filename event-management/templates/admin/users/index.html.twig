{% extends 'base.html.twig' %}

{% block title %}Manage Users - Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
{% endblock %}

{% block body %}
    <div class="admin-wrapper">
        <!-- Sidebar -->
        <aside class="admin-sidebar">
            <div class="sidebar-header">
                <i class="bi bi-shield-lock"></i>
                <span>Admin Panel</span>
            </div>
            
            <nav class="sidebar-nav">
                <a href="{{ path('app_admin_dashboard') }}" class="nav-link">
                    <i class="bi bi-speedometer2"></i>
                    Dashboard
                </a>
                <a href="{{ path('app_admin_events') }}" class="nav-link">
                    <i class="bi bi-calendar-event"></i>
                    Events
                </a>
                <a href="{{ path('app_admin_reservations') }}" class="nav-link">
                    <i class="bi bi-ticket"></i>
                    Reservations
                </a>
                <a href="{{ path('app_admin_users') }}" class="nav-link active">
                    <i class="bi bi-people"></i>
                    Users
                </a>
            </nav>
            
            <div class="sidebar-footer">
                <a href="{{ path('app_home') }}" class="nav-link">
                    <i class="bi bi-house-door"></i>
                    Back to Site
                </a>
                <a href="{{ path('app_logout') }}" class="nav-link text-danger">
                    <i class="bi bi-box-arrow-right"></i>
                    Logout
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="admin-main">
            <div class="admin-header">
                <h1>Manage Users</h1>
                <div class="header-actions">
                    <span class="total-count">Total: {{ users|length }}</span>
                </div>
            </div>

            <div class="admin-content">
                <!-- Users Table -->
                <div class="admin-card">
                    <div class="card-body">
                        {% if users is empty %}
                            <div class="empty-state">
                                <i class="bi bi-people"></i>
                                <h3>No Users Found</h3>
                            </div>
                        {% else %}
                            <div class="table-responsive">
                                <table class="admin-table">
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Name</th>
                                            <th>Email</th>
                                            <th>Roles</th>
                                            <th>Registered</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for user in users %}
                                            <tr>
                                                <td>#{{ user.id }}</td>
                                                <td>{{ user.fullName }}</td>
                                                <td>{{ user.email }}</td>
                                                <td>
                                                    {% if 'ROLE_ADMIN' in user.roles %}
                                                        <span class="badge bg-danger">Admin</span>
                                                    {% else %}
                                                        <span class="badge bg-secondary">User</span>
                                                    {% endif %}
                                                </td>
                                                <td>{{ user.createdAt ? user.createdAt|date('M d, Y') : 'N/A' }}</td>
                                                <td>
                                                    {% if user.id != app.user.id %}
                                                        <form method="post" action="{{ path('app_admin_user_toggle_role', {'id': user.id}) }}" 
                                                              style="display: inline-block;">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ user.id) }}">
                                                            <button type="submit" class="btn-icon" 
                                                                    title="{{ 'ROLE_ADMIN' in user.roles ? 'Remove Admin' : 'Make Admin' }}">
                                                                {% if 'ROLE_ADMIN' in user.roles %}
                                                                    <i class="bi bi-shield-slash text-danger"></i>
                                                                {% else %}
                                                                    <i class="bi bi-shield text-success"></i>
                                                                {% endif %}
                                                            </button>
                                                        </form>
                                                    {% endif %}
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </main>
    </div>
{% endblock %}